// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}


model Order {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  customerName String

  phoneNumber String

  location String

  bags Int

  notes String?

  status OrderStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

model SearchQuery {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  query     String
  createdAt DateTime @default(now())

  @@index([query])
  @@index([createdAt])
}